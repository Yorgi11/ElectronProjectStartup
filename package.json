{
  "name": "electronprojectstartup",
  "version": "1.0.0",
  "description": "Create a new Electron project folder on the desktop and open it in VS Code",
  "main": "main.js",
  "author": "Michael Giorgi",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.quickfox.electronprojectstartup",
    "productName": "ElectronProjectStartup",
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    }
  }
}
